<?xml version="1.0" encoding="utf-8"?>
<!-- Тот же символ, что в иконке приложения, на белом круге — «вторая» картинка рядом. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="@dimen/splash_logo_dp"
        android:height="@dimen/splash_logo_dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>
    <item
        android:width="@dimen/splash_logo_inner_dp"
        android:height="@dimen/splash_logo_inner_dp"
        android:drawable="@drawable/ic_launcher_foreground"
        android:gravity="center" />
</layer-list>
