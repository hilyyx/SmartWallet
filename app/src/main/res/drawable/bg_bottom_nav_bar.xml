<?xml version="1.0" encoding="utf-8"?>
<!-- Белая панель + тонкая верхняя кромка как у карточки входа; тень задаётся elevation у BottomNavigationView -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
        </shape>
    </item>
    <item
        android:height="1dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/auth_card_stroke" />
        </shape>
    </item>
</layer-list>
