<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Раньше cleartext был только для пары фиксированных IP — любой другой LAN-адрес ПК
      (например 192.168.1.x) блокировался, и с реального телефона «не заходило» в сеть.

      Для разработки по HTTP разрешаем cleartext глобально. Для продакшена — только HTTPS
      и отдельный конфиг без cleartext.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>








