<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_button_lime"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/imageSplashLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:adjustViewBounds="true"
        android:contentDescription="@string/splash_screen_accessibility"
        android:importantForAccessibility="yes"
        android:maxWidth="@dimen/splash_center_logo_max"
        android:maxHeight="@dimen/splash_center_logo_max"
        android:scaleType="fitCenter"
        android:src="@drawable/vector" />
</FrameLayout>
