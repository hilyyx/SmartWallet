<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_content_padding_horizontal"
        android:paddingEnd="@dimen/screen_content_padding_horizontal"
        android:paddingTop="@dimen/screen_content_padding_top"
        android:paddingBottom="@dimen/screen_content_padding_horizontal"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Шапка -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/home_block_spacing">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Главный экран"
                android:textAppearance="@style/SmartWalletScreenTitle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_title_subtitle_spacing"
                android:text="Активная карта и подсказки для оплаты"
                android:textAppearance="@style/SmartWalletScreenSubtitle" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardActiveCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/home_block_spacing"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/home_bank_card_corner"
            app:cardElevation="@dimen/home_card_glow_elevation"
            app:strokeWidth="0dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/textActiveCardSectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Активная карта"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/textActiveCardNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="•••• 1234"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/textActiveCardName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visa Gold"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/textActiveCardBank"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Сбербанк"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:alpha="0.8"/>

                    <TextView
                        android:id="@+id/textActiveCardCashback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5% кэшбэк"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecommendedCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/home_block_bet_spacing"
            app:cardCornerRadius="@dimen/home_category_corner"
            app:cardElevation="@dimen/home_advice_cards_elevation"
            app:strokeWidth="0dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/brand_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/textRecommendedCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Рекомендованная категория: 🛒 Еда — 5%"
                    android:textColor="@color/brand_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecommendationBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="54dp"
            app:cardBackgroundColor="@color/brand_card_bg"
            app:cardCornerRadius="@dimen/home_recommend_corner"
            app:cardElevation="@dimen/home_advice_cards_elevation"
            app:strokeWidth="0dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="340dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textRecommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="Рекомендую оплатить картой Тинькофф Black — 5% кэшбэк"
                    android:textColor="@color/black"
                    android:textSize="16sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Две кнопки без MaterialCardView: одинаковая ширина/высота/отступы от колонки -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSmartChoice"
            style="@style/Widget.SmartWallet.Button.FullWidth"
            android:layout_marginBottom="@dimen/home_block_spacing"
            android:stateListAnimator="@null"
            android:text="Умный выбор карты"
            android:textSize="16sp"
            app:elevation="@dimen/home_advice_cards_elevation"
            app:icon="@drawable/ic_ai_24"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonPay"
            style="@style/Widget.SmartWallet.Button.FullWidth"
            android:text="Оплатить"
            android:textSize="16sp"
            app:icon="@drawable/ic_credit_card"
            app:iconPadding="8dp"
            app:iconGravity="textStart" />
    </LinearLayout>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/md_theme_primary" />

</FrameLayout>
