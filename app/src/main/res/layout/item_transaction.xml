<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="-5dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/brand_card_bg"
    app:cardCornerRadius="@dimen/home_category_corner"
    app:cardElevation="@dimen/home_advice_cards_elevation"
    app:cardUseCompatPadding="true"
    app:strokeColor="@android:color/transparent"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="10dp">

        <!-- Плитка категории (как на макете) -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_transaction_category_tile">

            <ImageView
                android:id="@+id/imageCategory"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                tools:src="@drawable/ic_txn_category_food" />
        </FrameLayout>

        <!-- Центр: время + категория (+ бейдж источника) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="13sp"
                tools:text="14:32" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/black"
                    android:textSize="17sp"
                    tools:text="Еда" />

                <TextView
                    android:id="@+id/textSourceBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_badge_source"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_theme_onPrimaryContainer"
                    android:visibility="gone"
                    tools:text="ДЕМО" />
            </LinearLayout>
        </LinearLayout>

        <!-- Правый край: карта, сумма, кэшбэк -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="12sp"
                tools:text="Карта #1" />

            <TextView
                android:id="@+id/textAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/transaction_amount_debit"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="-1 250.00 ₽" />

            <TextView
                android:id="@+id/textCashback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_transaction_cashback_chip"
                android:paddingHorizontal="7dp"
                android:paddingVertical="3dp"
                android:textColor="@color/transaction_cashback_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="+25.00 ₽" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
