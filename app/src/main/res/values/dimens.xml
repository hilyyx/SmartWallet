<?xml version="1.0" encoding="utf-8"?>
<resources>
    <dimen name="smartwallet_button_width">340dp</dimen>
    <dimen name="smartwallet_button_height">65dp</dimen>
    <dimen name="smartwallet_button_corner">21dp</dimen>
    <!-- Главный экран: +3dp к радиусам относительно прежних значений в разметке -->
    <dimen name="home_button_corner">24dp</dimen>
    <dimen name="home_bank_card_corner">23dp</dimen>
    <dimen name="home_category_corner">19dp</dimen>
    <dimen name="home_recommend_corner">15dp</dimen>
    <!-- Главная: одинаковый шаг между активной картой, советами и кнопками -->
    <dimen name="home_block_spacing">16dp</dimen>
    <dimen name="home_block_bet_spacing">-8dp</dimen>
    <!-- Главная: тень у активной карты / кнопки «Оплатить» -->
    <dimen name="home_card_glow_elevation">12dp</dimen>
    <!-- Тень у блоков советов (категория + текст рекомендации) -->
    <dimen name="home_advice_cards_elevation">6dp</dimen>
    <!-- Сдвиг контента вниз на основных экранах (не вход/регистрация) -->
    <dimen name="screen_content_extra_top">16dp</dimen>
    <!-- Единые отступы шапки как на экране «Мои карты» -->
    <dimen name="screen_content_padding_top">48dp</dimen>
    <dimen name="screen_content_padding_horizontal">32dp</dimen>
    <dimen name="screen_header_margin_bottom">12dp</dimen>
    <dimen name="screen_title_subtitle_spacing">2dp</dimen>
    <!-- Вход / регистрация: чуть шире поля — меньше отступы от края экрана -->
    <dimen name="auth_form_screen_padding_horizontal">16dp</dimen>
    <!-- Внутренний отступ у карточки поля (сумма с padding ≈ край рамки поля от экрана) -->
    <dimen name="auth_form_field_horizontal_inset">4dp</dimen>
    <!-- Карточка вкладок: выровняна по внешнему краю полей (padding + field inset) -->
    <dimen name="auth_form_tab_card_margin_horizontal">20dp</dimen>
    <!-- Чуть пространства над первым полем — чтобы не обрезалось свечение (outline) -->
    <dimen name="auth_form_first_field_extra_top">8dp</dimen>
</resources>
